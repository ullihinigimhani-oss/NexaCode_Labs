{
  "info": {
    "_postman_id": "69bb2d92-0177-4efc-a417-56a4b9071882",
    "name": "NexaCode Labs Auth API",
    "description": "Complete Postman collection for the NexaCode Labs authentication backend. Uses the local environment variables in NexaCode-Labs-Local.postman_environment.json.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const contentType = pm.response.headers.get('Content-Type') || '';",
          "const text = pm.response.text() || '';",
          "let json = null;",
          "if (contentType.includes('application/json') && text) {",
          "  try { json = pm.response.json(); } catch (error) { json = null; }",
          "}",
          "",
          "pm.test('Response time is reasonable', function () {",
          "  pm.expect(pm.response.responseTime).to.be.below(3000);",
          "});",
          "",
          "if (json) {",
          "  pm.test('Response has success boolean', function () {",
          "    pm.expect(json).to.have.property('success');",
          "    pm.expect(json.success).to.be.a('boolean');",
          "  });",
          "  pm.test('Response has message string', function () {",
          "    pm.expect(json).to.have.property('message');",
          "    pm.expect(json.message).to.be.a('string');",
          "  });",
          "  if (json.success === false) {",
          "    pm.test('Error response has errors array', function () {",
          "      pm.expect(json).to.have.property('errors');",
          "      pm.expect(json.errors).to.be.an('array');",
          "    });",
          "  }",
          "}",
          "",
          "pm.test('No secret fields are leaked', function () {",
          "  pm.expect(text).to.not.include('password_hash');",
          "  pm.expect(text).to.not.include('otp_hash');",
          "  pm.expect(text).to.not.include('token_hash');",
          "});",
          "",
          "pm.test('No internal stack trace is exposed', function () {",
          "  pm.expect(text).to.not.include('at Layer.handle');",
          "  pm.expect(text).to.not.include('node_modules');",
          "});"
        ]
      }
    }
  ],
